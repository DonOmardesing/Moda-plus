<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>INSIDE-MIND</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Inter',sans-serif;
}

body{
background:#050505;
color:white;
overflow-x:hidden;
}

.background{
position:fixed;
width:100%;
height:100%;
background:
radial-gradient(circle at top left,#1d4ed8 0%,transparent 30%),
radial-gradient(circle at bottom right,#0f172a 0%,transparent 30%),
#050505;
z-index:-1;
}

header{
padding:40px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:2.5rem;
font-weight:800;
letter-spacing:-2px;
}

.subtitle{
color:#94a3b8;
margin-top:10px;
font-size:1rem;
}

.dashboard{
padding:20px 40px 60px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.08);
backdrop-filter:blur(10px);
border-radius:28px;
padding:28px;
transition:0.3s ease;
cursor:pointer;
position:relative;
overflow:hidden;
}

.card:hover{
transform:translateY(-8px);
border:1px solid #3b82f6;
box-shadow:0 0 30px rgba(59,130,246,0.25);
}

.card::before{
content:'';
position:absolute;
width:120%;
height:120%;
background:linear-gradient(
45deg,
transparent,
rgba(59,130,246,0.08),
transparent
);
top:-50%;
left:-50%;
transform:rotate(25deg);
}

.card h2{
font-size:1.7rem;
margin-bottom:15px;
position:relative;
z-index:2;
}

.card p{
color:#cbd5e1;
line-height:1.6;
position:relative;
z-index:2;
}

.ai-box{
margin:40px;
padding:30px;
border-radius:30px;
background:linear-gradient(135deg,#2563eb20,#0f172a);
border:1px solid rgba(59,130,246,0.3);
backdrop-filter:blur(12px);
}

.ai-box h3{
font-size:1.8rem;
margin-bottom:15px;
}

.ai-box p{
color:#cbd5e1;
font-size:1.1rem;
line-height:1.8;
}

.footer{
padding:30px;
text-align:center;
color:#64748b;
}

.glow{
color:#60a5fa;
}

.topbar{
display:flex;
gap:15px;
align-items:center;
}

.search{
padding:12px 18px;
background:#111827;
border:1px solid #1f2937;
border-radius:14px;
color:white;
outline:none;
width:260px;
}

.status{
padding:10px 18px;
border-radius:14px;
background:#111827;
border:1px solid #1f2937;
color:#60a5fa;
font-size:0.9rem;
}

</style>
</head>

<body>

<div class="background"></div>

<header>

<div>
<div class="logo">
INSIDE<span class="glow">-MIND</span>
</div>

<div class="subtitle">
Your intelligent knowledge ecosystem
</div>
</div>

<div class="topbar">

<input 
type="text" 
class="search"
placeholder="Search knowledge..."
>

<div class="status">
AI ACTIVE
</div>

</div>

</header>

<section class="ai-box">

<h3>
Good evening Omar.
</h3>

<p id="dailyMessage">
Analyzing global information streams...
</p>

</section>

<section class="dashboard">

<div class="card" onclick="openSection('Pulse')">
<h2>Pulse</h2>
<p>
AI and technology news filtered intelligently.
Only high-value information.
</p>
</div>

<div class="card" onclick="openSection('Echo')">
<h2>Echo</h2>
<p>
TED Talks, finance videos and podcasts summarized in under 60 seconds.
</p>
</div>

<div class="card" onclick="openSection('Lingua')">
<h2>Lingua</h2>
<p>
Practical English phrases, grammar and pronunciation for daily life.
</p>
</div>

<div class="card" onclick="openSection('Vision')">
<h2>Vision</h2>
<p>
Photography tips, TikTok content ideas and visual storytelling.
</p>
</div>

<div class="card" onclick="openSection('Mystery')">
<h2>Mystery</h2>
<p>
Alien stories, ancient civilizations and documentary-style mysteries.
</p>
</div>

<div class="card" onclick="openSection('AI Core')">
<h2>AI Core</h2>
<p>
Your personalized intelligence engine learns what truly matters to you.
</p>
</div>

</section>

<div class="footer">
INSIDE-MIND © 2026
</div>

<script>

const messages = [

"Today I found 7 valuable things for your growth.",

"2 important AI breakthroughs were detected today.",

"A new TED Talk about discipline is trending now.",

"Financial markets show interesting movement today.",

"3 practical English expressions were added to your learning queue.",

"A mysterious archaeological discovery is gaining attention online."

];

function randomMessage(){

const random = Math.floor(Math.random() * messages.length);

document.getElementById("dailyMessage").innerText = messages[random];

}

setInterval(randomMessage,5000);

function openSection(section){

alert(
"Inside-Mind AI will soon open the " + section + " intelligence module."
);

}

randomMessage();

</script>

</body>
</html>